{
    "name": "vet",
    "displayName": "Vet",
    "description": "Detect secrets in your code before they leak",
    "version": "0.1.0",
    "publisher": "vet",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/spikermint/vet"
    },
    "homepage": "https://github.com/spikermint/vet",
    "bugs": {
        "url": "https://github.com/spikermint/vet/issues"
    },
    "engines": {
        "vscode": "^1.90.0",
        "node": ">=22"
    },
    "categories": [
        "Linters"
    ],
    "keywords": [
        "security",
        "secrets",
        "credentials",
        "scanner",
        "api-keys"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "files": [
        "dist",
        "server"
    ],
    "icon": "icon.png",
    "contributes": {
        "configuration": {
            "title": "Vet",
            "properties": {
                "vet.enable": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Vet secret scanning"
                },
                "vet.serverPath": {
                    "type": "string",
                    "default": "",
                    "scope": "machine-overridable",
                    "markdownDescription": "Path to `vet-lsp` binary. Leave empty to use the bundled server. Primarily useful for extension development."
                },
                "vet.includeLowConfidence": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show low-confidence findings (likely placeholders or examples)"
                },
                "vet.respectGitignore": {
                    "type": "boolean",
                    "default": true,
                    "description": "Skip files ignored by .gitignore"
                },
                "vet.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Trace communication with the language server (for debugging)"
                }
            }
        },
        "commands": [
            {
                "command": "vet.restart",
                "title": "Restart Language Server",
                "category": "Vet"
            }
        ]
    },
    "scripts": {
        "compile": "npm run typecheck && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run typecheck && node esbuild.js --production",
        "lint": "biome check src",
        "lint:fix": "biome check --write src",
        "format": "biome format --write src",
        "typecheck": "tsc --noEmit",
        "vscode:prepublish": "npm run package"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.11",
        "@types/node": "^25.0.10",
        "@types/vscode": "1.90.0",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.27.2",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3"
    }
}